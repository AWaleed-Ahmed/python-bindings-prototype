flowchart TD
    A["Moose primitives + MooseCSG graph"] --> B["Exporter traversal\n_export_moose_native_node(...)"]
    B --> C["Primitive creation dispatch\ncreate_sphere/create_box/create_cylinder/create_ell/create_tgc"]
    B --> D["Combination write path\ncreate_combination + comb_add_member(..., matrix)"]
    C --> E["Database facade methods"]
    D --> E
    E --> F["_brlcad C extension bridge"]
    F --> G["adapter layer + BRL-CAD core"]
    G --> H["Persistent .g output"]

    A1["src/brlcad/moose.py\nMooseSphere/Box/Cylinder/ELL/TGC\nMooseCSG"]:::loc
    B1["src/brlcad/exporter.py\n_is_moose_native_node\n_export_moose_native_node"]:::loc
    C1["src/brlcad/exporter.py\nprimitive branches call db.create_*"]:::loc
    D1["src/brlcad/exporter.py\n_member_matrix + _build_transform_matrix\ncomb_add_member(..., matrix)"]:::loc
    E1["src/brlcad/database.py\ncreate_* facade methods"]:::loc
    F1["src/_brlcad/module.c\npy_brlcad_* wrappers"]:::loc
    G1["src/adapter/*.c\nDB + combination adapters"]:::loc

    A1 -. defines .-> A
    B1 -. traversal .-> B
    C1 -. primitive writes .-> C
    D1 -. matrix member writes .-> D
    E1 -. facade .-> E
    F1 -. CPython bridge .-> F
    G1 -. native calls .-> G

    classDef loc fill:#111,color:#fff,stroke:#fff,stroke-width:1px;
    classDef main fill:#000,color:#fff,stroke:#fff,stroke-width:1.2px;
    class A,B,C,D,E,F,G,H main;
